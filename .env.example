# Application
APP_ENV=development
PORT=8081
DEBUG=false

# MongoDB
MONGO_URI=mongodb://localhost:27018
MONGO_DATABASE=orchestration
MONGO_USERNAME=
MONGO_PASSWORD=

# NATS
NATS_URL=nats://localhost:4222
NATS_STREAM=WORKFLOW_EVENTS
NATS_SUBJECT=workflow.events.>

# Workflow
WORKFLOW_STORE=mongo

# Cassandra
CASSANDRA_HOSTS=localhost
CASSANDRA_KEYSPACE=orchestration
CASSANDRA_PORT=9042

# Migration Phase: shadow | read_switch | cleanup
MIGRATION_PHASE=shadow
